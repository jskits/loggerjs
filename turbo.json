{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".oxfmtrc.jsonc",
    ".oxlintrc.json",
    "pnpm-lock.yaml",
    "rolldown.config.mjs",
    "tsconfig.base.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
