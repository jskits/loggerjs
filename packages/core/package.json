{
  "name": "@loggerjs/core",
  "version": "0.5.4",
  "description": "Tiny isomorphic structured logger core for loggerjs.",
  "homepage": "https://github.com/jskits/loggerjs/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/jskits/loggerjs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jskits/loggerjs.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./codec-json": {
      "types": "./dist/codecs/json.d.ts",
      "import": "./dist/codec-json.js",
      "require": "./dist/codec-json.cjs"
    },
    "./codec-metrics": {
      "types": "./dist/codecs/metrics.d.ts",
      "import": "./dist/codec-metrics.js",
      "require": "./dist/codec-metrics.cjs"
    },
    "./transport-console": {
      "types": "./dist/transports/console.d.ts",
      "import": "./dist/transport-console.js",
      "require": "./dist/transport-console.cjs"
    },
    "./transport-batch": {
      "types": "./dist/transports/batch.d.ts",
      "import": "./dist/transport-batch.js",
      "require": "./dist/transport-batch.cjs"
    },
    "./transport-reliability": {
      "types": "./dist/transports/reliability.d.ts",
      "import": "./dist/transport-reliability.js",
      "require": "./dist/transport-reliability.cjs"
    },
    "./transport-test": {
      "types": "./dist/transports/test.d.ts",
      "import": "./dist/transport-test.js",
      "require": "./dist/transport-test.cjs"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.cjs"
    },
    "./trace-propagation": {
      "types": "./dist/trace-propagation.d.ts",
      "import": "./dist/trace-propagation.js",
      "require": "./dist/trace-propagation.cjs"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "import": "./dist/events.js",
      "require": "./dist/events.cjs"
    },
    "./semantic-events": {
      "types": "./dist/semantic-events.d.ts",
      "import": "./dist/semantic-events.js",
      "require": "./dist/semantic-events.cjs"
    },
    "./payload-transforms": {
      "types": "./dist/payload-transforms.d.ts",
      "import": "./dist/payload-transforms.js",
      "require": "./dist/payload-transforms.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
    "build:js": "rolldown -c ../../rolldown.config.mjs",
    "build:types": "tsc -p tsconfig.build.json && node ../../scripts/fix-dts-extensions.mjs dist",
    "typecheck:no-dom": "tsc --noEmit -p tsconfig.no-dom.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "loggerjsSubpathEntries": {
    "middleware": "src/middleware.ts",
    "codec-json": "src/codecs/json.ts",
    "codec-metrics": "src/codecs/metrics.ts",
    "transport-console": "src/transports/console.ts",
    "transport-batch": "src/transports/batch.ts",
    "transport-reliability": "src/transports/reliability.ts",
    "transport-test": "src/transports/test.ts",
    "context": "src/context.ts",
    "trace-propagation": "src/trace-propagation.ts",
    "events": "src/events.ts",
    "semantic-events": "src/semantic-events.ts",
    "payload-transforms": "src/payload-transforms.ts"
  }
}
